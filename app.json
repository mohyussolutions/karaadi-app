{
  "expo": {
    "name": "Karaadi",
    "slug": "karaadi",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "karaadi",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.karaadi.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": []
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.karaadi.app",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "versionCode": 12
    },
    "plugins": [
      "./plugins/withAbiFilters",
      "expo-router",
      "expo-status-bar",
      [
        "expo-font",
        {
          "fonts": [
            "./node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/MaterialCommunityIcons.ttf",
            "./node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/MaterialIcons.ttf",
            "./node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/Ionicons.ttf"
          ]
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2563EB",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Karaadi to access your photos to add images to your listings.",
          "cameraPermission": "Allow Karaadi to use your camera to take photos for your listings."
        }
      ],
      "expo-audio",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.jpg",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-video"
    ],
    "extra": {
      "eas": {
        "projectId": "8b1bceed-00e0-4430-ad28-bdd19d638fcd"
      },
      "router": {}
    },
    "owner": "karaadi",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8b1bceed-00e0-4430-ad28-bdd19d638fcd"
    }
  }
}
