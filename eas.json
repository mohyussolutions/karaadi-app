{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://karaadi.onrender.com"
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://karaadi.onrender.com"
      },
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://karaadi.onrender.com"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      },
      "ios": {
        "ascApiKeyPath": "./AuthKey_T4K9ZTB9VV.p8",
        "ascApiKeyIssuerId": "c60673ac-14fe-4ffb-ada0-b2ced34faf6f",
        "ascApiKeyId": "T4K9ZTB9VV",
        "appleTeamId": "PPPF27LDWQ",
        "ascAppId": "6780579199"
      }
    }
  }
}
